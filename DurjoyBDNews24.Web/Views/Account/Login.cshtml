@{
    ViewData["Title"] = "লগইন";
    Layout = "_Layout";
}

<div style="max-width:440px;margin:40px auto;">
    <div style="background:white;border-radius:12px;padding:32px;border:0.5px solid #e0e0e0;">
        <h2 style="font-size:22px;text-align:center;margin-bottom:24px;color:#1a1a1a;">
            লগইন করুন
        </h2>

        @if (ViewBag.Error != null)
        {
            <div style="background:#fde8e8;color:#c0392b;padding:12px;border-radius:6px;font-size:14px;margin-bottom:16px;">
                <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
            </div>
        }

        <form method="post" asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl">
            <div style="margin-bottom:16px;">
                <label style="display:block;font-size:13px;font-weight:500;color:#444;margin-bottom:6px;">
                    ইমেইল
                </label>
                <input type="email"
                       name="email"
                       placeholder="আপনার ইমেইল"
                       required
                       style="width:100%;padding:10px 14px;border:0.5px solid #ddd;border-radius:6px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box;" />
            </div>
            <div style="margin-bottom:20px;">
                <label style="display:block;font-size:13px;font-weight:500;color:#444;margin-bottom:6px;">
                    পাসওয়ার্ড
                </label>
                <input type="password"
                       name="password"
                       placeholder="পাসওয়ার্ড"
                       required
                       style="width:100%;padding:10px 14px;border:0.5px solid #ddd;border-radius:6px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box;" />
            </div>
            <button type="submit"
                    style="width:100%;padding:12px;background:#c0392b;color:white;border:none;border-radius:6px;font-size:15px;cursor:pointer;font-family:inherit;font-weight:500;">
                লগইন
            </button>
        </form>

        <div style="text-align:center;margin-top:20px;font-size:14px;color:#888;">
            একাউন্ট নেই?
            <a asp-controller="Account"
               asp-action="Register"
               style="color:#c0392b;text-decoration:none;font-weight:500;">
                রেজিস্ট্রেশন করুন
            </a>
        </div>
    </div>
</div>