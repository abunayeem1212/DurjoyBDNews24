@model DurjoyBDNews24.Web.Models.ProfileViewModel
@{
    ViewData["Title"] = "আমার প্রোফাইল";
    Layout = "_Layout";
}

<div style="max-width:800px;margin:32px auto;">

    <div style="background:white;border-radius:12px;padding:28px;border:0.5px solid #e0e0e0;margin-bottom:20px;">
        <div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;padding-bottom:20px;border-bottom:0.5px solid #f0f0f0;">
            <div style="width:72px;height:72px;border-radius:50%;background:#c0392b;color:white;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:700;flex-shrink:0;">
                @(Model.FullNameBn?.Length > 0
                                ? Model.FullNameBn[0].ToString() : "প")
            </div>
            <div style="flex:1;">
                <h2 style="font-size:22px;margin:0 0 4px;color:#1a1a1a;">
                    @Model.FullNameBn
                </h2>
                <p style="font-size:14px;color:#888;margin:0;">
                    @Model.Email
                </p>
                <div style="display:flex;gap:8px;margin-top:8px;">
                    <span style="padding:3px 12px;border-radius:20px;font-size:12px;font-weight:500;background:#fde8e8;color:#c0392b;">
                        @Model.Role
                    </span>
                    @if (Model.IsPremium)
                    {
                        <span style="padding:3px 12px;border-radius:20px;font-size:12px;font-weight:500;background:#d4edda;color:#155724;">
                            <i class="fas fa-crown"></i> Premium
                        </span>
                    }
                </div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
            <div style="text-align:center;padding:16px;background:#f9f9f9;border-radius:8px;">
                <p style="font-size:24px;font-weight:700;color:#c0392b;margin:0;">
                    @Model.RecentComments.Count()
                </p>
                <p style="font-size:13px;color:#888;margin:4px 0 0;">মন্তব্য</p>
            </div>
            <div style="text-align:center;padding:16px;background:#f9f9f9;border-radius:8px;">
                <p style="font-size:24px;font-weight:700;color:#c0392b;margin:0;">
                    @(Model.IsPremium ? "Active" : "Free")
                </p>
                <p style="font-size:13px;color:#888;margin:4px 0 0;">সাবস্ক্রিপশন</p>
            </div>
            <div style="text-align:center;padding:16px;background:#f9f9f9;border-radius:8px;">
                <p style="font-size:24px;font-weight:700;color:#c0392b;margin:0;">
                    @Model.Role
                </p>
                <p style="font-size:13px;color:#888;margin:4px 0 0;">ভূমিকা</p>
            </div>
        </div>
    </div>

    @if (Model.Subscription is not null && Model.IsPremium)
    {
        <div style="background:linear-gradient(135deg,#c0392b,#922b21);border-radius:12px;padding:24px;margin-bottom:20px;color:white;">
            <div style="display:flex;justify-content:space-between;align-items:center;">
                <div>
                    <p style="font-size:13px;opacity:0.8;margin:0 0 4px;">
                        <i class="fas fa-crown"></i> সক্রিয় সাবস্ক্রিপশন
                    </p>
                    <h3 style="font-size:22px;margin:0;">
                        @Model.Subscription.PlanName Plan
                    </h3>
                    <p style="font-size:13px;opacity:0.8;margin:8px 0 0;">
                        মেয়াদ: @Model.Subscription.EndDate.ToString("dd MMMM yyyy") পর্যন্ত
                    </p>
                </div>
                <div style="text-align:right;">
                    <p style="font-size:28px;font-weight:700;margin:0;">
                        ৳@Model.Subscription.Amount
                    </p>
                    <p style="font-size:12px;opacity:0.7;margin:4px 0 0;">প্রতি মাস</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div style="background:white;border-radius:12px;padding:24px;margin-bottom:20px;border:0.5px solid #e0e0e0;">
            <h3 style="font-size:17px;margin:0 0 16px;">
                Premium সাবস্ক্রিপশন নিন
            </h3>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div style="border:0.5px solid #e0e0e0;border-radius:8px;padding:20px;">
                    <h4 style="font-size:16px;margin:0 0 8px;">Basic</h4>
                    <p style="font-size:28px;font-weight:700;color:#c0392b;margin:0 0 12px;">
                        ৳৯৯<span style="font-size:14px;font-weight:400;color:#888;">/মাস</span>
                    </p>
                    <ul style="list-style:none;font-size:13px;color:#555;">
                        <li style="padding:4px 0;">
                            <i class="fas fa-check" style="color:#27ae60;margin-right:6px;"></i>
                            বিজ্ঞাপনমুক্ত পড়া
                        </li>
                        <li style="padding:4px 0;">
                            <i class="fas fa-check" style="color:#27ae60;margin-right:6px;"></i>
                            Breaking news notification
                        </li>
                    </ul>
                    <button onclick="subscribe('Basic')"
                            style="width:100%;padding:10px;background:#c0392b;color:white;border:none;border-radius:6px;margin-top:16px;cursor:pointer;font-size:14px;font-family:inherit;">
                        সাবস্ক্রাইব করুন
                    </button>
                </div>
                <div style="border:2px solid #c0392b;border-radius:8px;padding:20px;position:relative;">
                    <span style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#c0392b;color:white;padding:2px 16px;border-radius:20px;font-size:12px;white-space:nowrap;">
                        সেরা মূল্য
                    </span>
                    <h4 style="font-size:16px;margin:0 0 8px;">Premium</h4>
                    <p style="font-size:28px;font-weight:700;color:#c0392b;margin:0 0 12px;">
                        ৳১৯৯<span style="font-size:14px;font-weight:400;color:#888;">/মাস</span>
                    </p>
                    <ul style="list-style:none;font-size:13px;color:#555;">
                        <li style="padding:4px 0;">
                            <i class="fas fa-check" style="color:#27ae60;margin-right:6px;"></i>
                            Basic এর সব সুবিধা
                        </li>
                        <li style="padding:4px 0;">
                            <i class="fas fa-check" style="color:#27ae60;margin-right:6px;"></i>
                            Exclusive content
                        </li>
                        <li style="padding:4px 0;">
                            <i class="fas fa-check" style="color:#27ae60;margin-right:6px;"></i>
                            PDF download
                        </li>
                    </ul>
                    <button onclick="subscribe('Premium')"
                            style="width:100%;padding:10px;background:#c0392b;color:white;border:none;border-radius:6px;margin-top:16px;cursor:pointer;font-size:14px;font-family:inherit;">
                        সাবস্ক্রাইব করুন
                    </button>
                </div>
            </div>
        </div>
    }

    @if (Model.RecentComments.Any())
    {
        <div style="background:white;border-radius:12px;padding:24px;border:0.5px solid #e0e0e0;">
            <h3 style="font-size:17px;margin:0 0 16px;border-bottom:2px solid #c0392b;padding-bottom:10px;">
                <i class="fas fa-comments" style="color:#c0392b;margin-right:8px;"></i>
                আমার মন্তব্যসমূহ
            </h3>
            @foreach (var comment in Model.RecentComments)
            {
                <div style="padding:12px 0;border-bottom:0.5px solid #f5f5f5;">
                    <p style="font-size:14px;color:#333;line-height:1.6;margin:0 0 6px;">
                        @comment.Content
                    </p>
                    <span style="font-size:12px;color:#aaa;">
                        @comment.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")
                    </span>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        async function subscribe(plan) {
            const token = sessionStorage.getItem('userToken');
            if (!token) {
                window.location.href = '/account/login';
                return;
            }

            try {
                const res = await fetch('@(ViewData["ApiBase"] ?? "https://localhost:7001/api/v1/")'
                    + 'payment/subscribe', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        plan: plan === 'Basic' ? 1 : 2,
                        userName: '@Model.FullNameBn',
                        email: '@Model.Email',
                        phone: ''
                    })
                });

                const data = await res.json();
                if (data.success && data.data?.gatewayUrl) {
                    window.location.href = data.data.gatewayUrl;
                } else {
                    alert(data.message || 'পেমেন্ট শুরু করা যায়নি');
                }
            } catch {
                alert('সংযোগ সমস্যা। আবার চেষ্টা করুন।');
            }
        }
    </script>
}