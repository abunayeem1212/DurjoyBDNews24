<script>
    (function(){
        // Carousel Module
        let currentCarouselSlide = 0;
        let carouselSlides = [];
        let carouselIndicators = [];
        let carouselInterval = null;

        function initCarousel() {
            carouselSlides = document.querySelectorAll('#featuredCarousel .carousel-slide');
            carouselIndicators = document.querySelectorAll('#featuredCarousel .indicator');
            if (carouselSlides.length > 0) {
                startCarouselAutoSlide();
            }
        }

        function showCarouselSlide(index) {
            if (!carouselSlides.length) return;
            if (index >= carouselSlides.length) index = 0;
            if (index < 0) index = carouselSlides.length - 1;

            carouselSlides.forEach(slide => slide.classList.remove('active'));
            carouselIndicators.forEach(ind => ind.classList.remove('active'));

            carouselSlides[index].classList.add('active');
            if (carouselIndicators[index]) {
                carouselIndicators[index].classList.add('active');
            }
            currentCarouselSlide = index;
        }

        window.nextCarouselSlide = function() {
            showCarouselSlide(currentCarouselSlide + 1);
            resetCarouselTimer();
        };

        window.prevCarouselSlide = function() {
            showCarouselSlide(currentCarouselSlide - 1);
            resetCarouselTimer();
        };

        window.goToCarouselSlide = function(index) {
            showCarouselSlide(index);
            resetCarouselTimer();
        };

        function startCarouselAutoSlide() {
            if (carouselInterval) clearInterval(carouselInterval);
            if (carouselSlides.length > 1) {
                carouselInterval = setInterval(() => window.nextCarouselSlide(), 4500);
            }
        }

        function resetCarouselTimer() {
            if (carouselInterval) {
                clearInterval(carouselInterval);
                startCarouselAutoSlide();
            }
        }

        // Touch Swipe
        let touchStartX = 0;
        function setupTouchSwipe() {
            const carousel = document.getElementById('featuredCarousel');
            if (!carousel) return;
            carousel.addEventListener('touchstart', (e) => {
                touchStartX = e.changedTouches[0].screenX;
            }, {passive: true});
            carousel.addEventListener('touchend', (e) => {
                const touchEndX = e.changedTouches[0].screenX;
                if (touchEndX < touchStartX - 50) window.nextCarouselSlide();
                if (touchEndX > touchStartX + 50) window.prevCarouselSlide();
            }, {passive: true});
        }

        document.addEventListener('DOMContentLoaded', function() {
            initCarousel();
            setupTouchSwipe();

            const carouselContainer = document.getElementById('featuredCarousel');
            if (carouselContainer) {
                carouselContainer.addEventListener('mouseenter', () => {
                    if (carouselInterval) clearInterval(carouselInterval);
                });
                carouselContainer.addEventListener('mouseleave', () => {
                    if (carouselSlides.length > 1) startCarouselAutoSlide();
                });
            }
        });
    })();

        async function loadHomeVideos() {
        try {
            const res = await fetch(`${apiBase}video/featured?count=4`);
            const data = await res.json();

            const section = document.getElementById('video-section');
            const grid = document.getElementById('video-grid');

            if (!section || !grid) return;
            if (!data.success || !data.data?.length) return;

            section.style.display = 'block';
            grid.innerHTML = data.data.map(v => `
                <a href="/video/watch/${v.id}"
                   style="display:block;text-decoration:none;background:white;border-radius:8px;overflow:hidden;border:0.5px solid #e0e0e0;">
                    <div style="position:relative;">
                        <img src="${v.thumbnailUrl || ''}"
                             alt="${v.titleBn}"
                             style="width:100%;height:120px;object-fit:cover;display:block;"
                             onerror="this.style.background='#1a1a2e';this.src=''"/>
                        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:32px;height:32px;background:rgba(192,57,43,0.85);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                            <i class="fas fa-play" style="color:white;font-size:10px;margin-left:2px;"></i>
                        </div>
                    </div>
                    <div style="padding:8px;">
                        <p style="font-size:12px;font-weight:500;color:#1a1a1a;margin:0;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                            ${v.titleBn}
                        </p>
                        <span style="font-size:11px;color:#aaa;margin-top:4px;display:block;">
                            <i class="fas fa-eye" style="font-size:9px;"></i>
                            ${v.viewCount} ভিউ
                        </span>
                    </div>
                </a>
            `).join('');
        } catch {}
    }

    document.addEventListener('DOMContentLoaded', () => {
        loadHomeVideos();
        loadComments();
    });


     
                function toggleDateFilter() {
                    const panel = document.getElementById('date-filter-panel');
                    const arrow = document.getElementById('date-filter-arrow');
                    const isOpen = panel.style.display === 'block';
                    panel.style.display = isOpen ? 'none' : 'block';
                    arrow.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
                }

                function applyDateFilter(value) {
                    let date = value;
                    const today = new Date();

                    if (value === 'today') {
                        date = today.toISOString().split('T')[0];
                    } else if (value === 'yesterday') {
                        const y = new Date(today);
                        y.setDate(y.getDate() - 1);
                        date = y.toISOString().split('T')[0];
                    } else if (value === 'week') {
                        const w = new Date(today);
                        w.setDate(w.getDate() - 7);
                        date = w.toISOString().split('T')[0];
                    } else if (value === 'month') {
                        const m = new Date(today);
                        m.setMonth(m.getMonth() - 1);
                        date = m.toISOString().split('T')[0];
                    }

                    const url = new URL(window.location.href);
                    if (date) {
                        url.searchParams.set('date', date);
                    } else {
                        url.searchParams.delete('date');
                    }
                    url.searchParams.set('page', '1');
                    window.location.href = url.toString();
                }

                @if (!string.IsNullOrEmpty(ViewBag.SelectedDate as string))
                {
                            <text>
                            document.addEventListener('DOMContentLoaded', () => {
                                const panel = document.getElementById('date-filter-panel');
                                const arrow = document.getElementById('date-filter-arrow');
                                if (panel) panel.style.display = 'block';
                                if (arrow) arrow.style.transform = 'rotate(180deg)';
                            });
                            </text>
                }


</script>