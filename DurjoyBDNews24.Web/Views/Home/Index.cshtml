<!-- Latest News Section -->
@if (Model.LatestArticles.Any())
{
    <div class="section-header">
        <h2 class="section-title">
            <i class="fas fa-clock"></i>
            সর্বশেষ সংবাদ
        </h2>
        <a href="/latest" class="view-all">
            সকল সংবাদ
            <i class="fas fa-arrow-left"></i>
        </a>
    </div>

    <div class="latest-grid">
        <div style="display:flex;flex-direction:column;gap:0;">
            @foreach (var item in Model.LatestArticles)
            {
                <a href="/news/@item.Slug"
                   style="display:flex;gap:14px;padding:16px 0;text-decoration:none;border-bottom:0.5px solid #f0f0f0;align-items:flex-start;">
                    @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                    {
                        <img src="@item.ThumbnailUrl"
                             alt="@item.TitleBn"
                             loading="lazy"
                             style="width:130px;height:85px;object-fit:cover;border-radius:6px;flex-shrink:0;" />
                    }
                    else
                    {
                        <div style="width:130px;height:85px;background:#f0f0f0;border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
                            <i class="fas fa-newspaper" style="color:#ccc;font-size:20px;"></i>
                        </div>
                    }
                    <div style="flex:1;">
                        <span style="background:#fde8e8;color:#c0392b;font-size:11px;padding:2px 8px;border-radius:10px;display:inline-block;margin-bottom:6px;">
                            <span data-bn="@item.CategoryNameBn"
                                  data-en="@item.CategoryName">
                                @item.CategoryNameBn
                            </span>
                        </span>
                        <h3 style="font-size:16px;font-weight:600;color:#1a1a1a;line-height:1.5;margin:0 0 8px;"
                            data-title-bn="@item.TitleBn"
                            data-title-en="@(string.IsNullOrEmpty(item.Title) ? item.TitleBn : item.Title)">
                            @item.TitleBn
                        </h3>
                        @if (!string.IsNullOrEmpty(item.SummaryBn))
                        {
                            <p style="font-size:13px;color:#666;margin:0 0 8px;line-height:1.6;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;"
                               data-bn="@item.SummaryBn"
                               data-en="@(item.Summary ?? item.SummaryBn)">
                                @item.SummaryBn
                            </p>
                        }
                        <div style="display:flex;gap:12px;font-size:12px;color:#999;">
                            <span>@item.PublishedAt?.ToString("dd MMM yyyy")</span>
                            <span>
                                <i class="fas fa-eye" style="font-size:10px;"></i>
                                @item.ViewCount
                            </span>
                        </div>
                    </div>
                </a>
            }
        </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" class="page-link" aria-label="পূর্ববর্তী পৃষ্ঠা">
                    <i class="fas fa-chevron-right"></i>
                </a>
            }

            @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
            {
                <a asp-action="Index" asp-route-page="@i" class="page-link @(i == Model.CurrentPage ? "active" : "")">
                    @i
                </a>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" class="page-link" aria-label="পরবর্তী পৃষ্ঠা">
                    <i class="fas fa-chevron-left"></i>
                </a>
            }
        </div>
    }
}

