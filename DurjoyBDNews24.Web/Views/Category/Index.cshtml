@model DurjoyBDNews24.Web.Models.CategoryViewModel
@{
    ViewData["Title"] = Model.CategoryName;
}

<div class="category-page">
    <div class="category-hero">
        <h1>@Model.CategoryName</h1>
        <p>@Model.Articles.Count() টি সংবাদ পাওয়া গেছে</p>
    </div>

    <div class="home-layout">
        <div class="main-col">
            @if (!Model.Articles.Any())
            {
                <div class="empty-state">
                    <p>এই বিভাগে এখনো কোনো সংবাদ নেই।</p>
                </div>
            }
            else
            {
                <div class="news-list">
                    @foreach (var article in Model.Articles)
                    {
                        <article class="news-card horizontal">
                            @if (!string.IsNullOrEmpty(article.ThumbnailUrl))
                            {
                                <img src="@article.ThumbnailUrl"
                                     alt="@article.TitleBn" />
                            }
                            else
                            {
                                <div class="no-image">
                                    <span>@article.CategoryNameBn</span>
                                </div>
                            }
                            <div class="card-body">
                                <span class="category-badge">
                                    @article.CategoryNameBn
                                </span>
                                <h3>
                                    <a asp-controller="News"
                                       asp-action="Detail"
                                       asp-route-slug="@article.Slug">
                                        @article.TitleBn
                                    </a>
                                </h3>
                                <p class="summary">@article.SummaryBn</p>
                                <div class="card-meta">
                                    <span>
                                        <i class="fas fa-user"></i>
                                        @article.AuthorNameBn
                                    </span>
                                    <span>
                                        <i class="fas fa-calendar"></i>
                                        @article.PublishedAt?.ToString("dd MMM yyyy")
                                    </span>
                                    <span>
                                        <i class="fas fa-eye"></i>
                                        @article.ViewCount
                                    </span>
                                </div>
                            </div>
                        </article>
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    <div class="pagination">
                        @if (Model.CurrentPage > 1)
                        {
                            <a asp-action="Index"
                               asp-route-slug="@Model.CategorySlug"
                               asp-route-page="@(Model.CurrentPage - 1)">
                                আগের পাতা
                            </a>
                        }
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <a asp-action="Index"
                               asp-route-slug="@Model.CategorySlug"
                               asp-route-page="@i"
                               class="@(i == Model.CurrentPage ? "active" : "")">
                                @i
                            </a>
                        }
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <a asp-action="Index"
                               asp-route-slug="@Model.CategorySlug"
                               asp-route-page="@(Model.CurrentPage + 1)">
                                পরের পাতা
                            </a>
                        }
                    </div>
                }
            }
        </div>

        <aside class="sidebar">
            <div class="widget">
                <h3 class="widget-title">সব বিভাগ</h3>
                <ul class="category-list">
                    @foreach (var cat in Model.Categories)
                    {
                        <li class="@(cat.Slug == Model.CategorySlug ? "active-cat" : "")">
                            <a asp-controller="Category"
                               asp-action="Index"
                               asp-route-slug="@cat.Slug">
                                @cat.NameBn
                            </a>
                        </li>
                    }
                </ul>
            </div>

            @if (Model.BreakingNews.Any())
            {
                <div class="widget">
                    <h3 class="widget-title">ব্রেকিং নিউজ</h3>
                    <ul class="breaking-list">
                        @foreach (var news in Model.BreakingNews.Take(5))
                        {
                            <li>
                                <a asp-controller="News"
                                   asp-action="Detail"
                                   asp-route-slug="@news.Slug">
                                    @news.TitleBn
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </aside>
    </div>
</div>