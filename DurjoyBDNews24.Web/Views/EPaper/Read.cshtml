@{
    ViewData["Title"] = "ই-পেপার পড়ুন";
    var epaper = ViewBag.EPaper as DurjoyBDNews24.Application.DTOs.EPaper.EPaperDto;
    var recent = ViewBag.RecentEPapers as IEnumerable<DurjoyBDNews24.Application.DTOs.EPaper.EPaperDto>;
}

@if (epaper != null)
{
    <div style="display:grid;grid-template-columns:1fr 260px;gap:24px;">
        <div>
            <div style="background:white;border-radius:8px;padding:16px 20px;border:0.5px solid #e0e0e0;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
                <div>
                    <h1 style="font-size:18px;margin:0 0 4px;color:#1a1a1a;">
                        @epaper.TitleBn
                    </h1>
                    <p style="font-size:13px;color:#888;margin:0;">
                        <i class="fas fa-calendar"></i>
                        @epaper.PublishDateBn
                        @if (!string.IsNullOrEmpty(epaper.Edition))
                        {
                            <span style="margin-left:8px;">| @epaper.Edition</span>
                        }
                    </p>
                </div>
                <div style="display:flex;gap:8px;">
                    @if (!epaper.IsPremiumOnly)
                    {
                        <a href="@epaper.PdfUrl"
                           target="_blank"
                           onclick="trackDownload(@epaper.Id)"
                           style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:#27ae60;color:white;border-radius:6px;text-decoration:none;font-size:13px;">
                            <i class="fas fa-download"></i> ডাউনলোড
                        </a>
                    }
                    <a href="/epaper"
                       style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:#f5f5f5;color:#333;border-radius:6px;text-decoration:none;font-size:13px;border:0.5px solid #ddd;">
                        <i class="fas fa-arrow-left"></i> আর্কাইভ
                    </a>
                </div>
            </div>

            <div style="background:#1a1a2e;border-radius:8px;overflow:hidden;position:relative;">
                @if (!epaper.IsPremiumOnly)
                {
                    <iframe src="@epaper.PdfUrl"
                            style="width:100%;height:80vh;border:none;display:block;"
                            title="@epaper.TitleBn">
                    </iframe>
                }
                else
                {
                    <div style="height:60vh;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;">
                        <i class="fas fa-lock" style="font-size:48px;color:#444;"></i>
                        <h3 style="color:white;font-size:20px;margin:0;">
                            Premium সদস্যদের জন্য
                        </h3>
                        <p style="color:#888;font-size:15px;margin:0;text-align:center;">
                            এই সংখ্যাটি পড়তে Premium সদস্যতা নিন
                        </p>
                        <a href="/account/profile"
                           style="padding:12px 24px;background:#c0392b;color:white;border-radius:6px;text-decoration:none;font-size:15px;">
                            Premium নিন
                        </a>
                    </div>
                }
            </div>
        </div>

        <aside>
            <div style="background:white;border-radius:8px;padding:16px;border:0.5px solid #e0e0e0;position:sticky;top:70px;">
                <h3 style="font-size:15px;margin:0 0 14px;border-bottom:2px solid #c0392b;padding-bottom:8px;">
                    পুরানো সংখ্যা
                </h3>
                @if (recent?.Any() == true)
                {
                    @foreach (var ep in recent)
                    {
                        <a href="/epaper/read/@ep.Id"
                           style="display:flex;gap:10px;margin-bottom:12px;text-decoration:none;padding:8px;border-radius:6px;@(ep.Id == epaper.Id ? "background:#fde8e8;" : "")">
                            @if (!string.IsNullOrEmpty(ep.ThumbnailUrl))
                            {
                                <img src="@ep.ThumbnailUrl"
                                     style="width:48px;height:64px;object-fit:cover;border-radius:4px;flex-shrink:0;" />
                            }
                            else
                            {
                                <div style="width:48px;height:64px;background:linear-gradient(135deg,#c0392b,#922b21);border-radius:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
                                    <i class="fas fa-newspaper" style="color:white;font-size:14px;opacity:0.7;"></i>
                                </div>
                            }
                            <div>
                                <p style="font-size:12px;font-weight:500;color:@(ep.Id == epaper.Id ? "#c0392b" : "#1a1a1a");margin:0 0 3px;line-height:1.4;">
                                    @ep.PublishDateBn
                                </p>
                                @if (!string.IsNullOrEmpty(ep.Edition))
                                {
                                    <span style="font-size:11px;color:#888;">
                                        @ep.Edition
                                    </span>
                                }
                                @if (ep.IsPremiumOnly)
                                {
                                    <span style="display:block;font-size:10px;color:#f39c12;margin-top:2px;">
                                        <i class="fas fa-crown"></i> Premium
                                    </span>
                                }
                            </div>
                        </a>
                    }
                }
            </div>
        </aside>
    </div>
}

@section Scripts {
    <script>
        async function trackDownload(id) {
            try {
                await fetch(`https://localhost:7001/api/v1/epaper/${id}/download`);
            } catch {}
        }
    </script>
}