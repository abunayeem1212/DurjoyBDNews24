@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string action = ViewBag.PagAction ?? "Index";
    string controller = ViewBag.PagController ?? "Home";
}

@if (totalPages > 1)
{
    <div style="display:flex;gap:6px;margin-top:24px;justify-content:center;flex-wrap:wrap;">
        @if (currentPage > 1)
        {
            <a asp-controller="@controller"
               asp-action="@action"
               asp-route-page="1"
               style="padding:8px 14px;border:0.5px solid #ddd;border-radius:6px;text-decoration:none;color:#444;font-size:13px;">
                «
            </a>
            <a asp-controller="@controller"
               asp-action="@action"
               asp-route-page="@(currentPage - 1)"
               style="padding:8px 14px;border:0.5px solid #ddd;border-radius:6px;text-decoration:none;color:#444;font-size:13px;">
                ‹ আগের
            </a>
        }

        @for (int i = Math.Max(1, currentPage - 2);
            i <= Math.Min(totalPages, currentPage + 2); i++)
        {
            <a asp-controller="@controller"
               asp-action="@action"
               asp-route-page="@i"
               style="padding:8px 14px;border-radius:6px;text-decoration:none;font-size:13px;@(i == currentPage ? "background:#c0392b;color:white;border:0.5px solid #c0392b;" : "border:0.5px solid #ddd;color:#444;")">
                @i
            </a>
        }

        @if (currentPage < totalPages)
        {
            <a asp-controller="@controller"
               asp-action="@action"
               asp-route-page="@(currentPage + 1)"
               style="padding:8px 14px;border:0.5px solid #ddd;border-radius:6px;text-decoration:none;color:#444;font-size:13px;">
                পরের ›
            </a>
            <a asp-controller="@controller"
               asp-action="@action"
               asp-route-page="@totalPages"
               style="padding:8px 14px;border:0.5px solid #ddd;border-radius:6px;text-decoration:none;color:#444;font-size:13px;">
                »
            </a>
        }
    </div>
}