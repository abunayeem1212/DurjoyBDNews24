            <div id="newsletter-msg" class="newsletter-msg"></div>
        </div>
    </div>

    <!-- ========== FOOTER ========== -->
    <footer class="footer">
        <div class="container">
            <div class="footer__grid">
                <div class="footer__about">
                    <div class="footer__logo">
                        <div class="footer__logo-icon" id="footerLogoIcon">
                            <span>দু</span>
                            <img id="footerLogoImg" src="/images/logo.png" alt="Logo" onerror="this.style.display='none'; document.getElementById('footerLogoIcon').classList.remove('has-logo');">
