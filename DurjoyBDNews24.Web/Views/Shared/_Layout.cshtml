    <div id="breaking-popup"
         style="display:none;position:fixed;bottom:80px;left:20px;max-width:320px;background:white;border-radius:10px;border-left:4px solid #e74c3c;box-shadow:0 8px 32px rgba(0,0,0,0.15);z-index:9998;overflow:hidden;">
        <div style="background:#e74c3c;padding:8px 14px;display:flex;justify-content:space-between;align-items:center;">
            <span style="color:white;font-size:13px;font-weight:600;display:flex;align-items:center;gap:6px;">
                <span style="width:8px;height:8px;background:white;border-radius:50%;animation:pulse 1.5s infinite;"></span>
