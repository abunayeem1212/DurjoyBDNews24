    </div>

    <script>
        let popupShown = false;

        connection.on('ReceiveBreakingNews', (news) => {
            if (!popupShown) return;
            showBreakingPopup(news.titleBn, `/news/${news.slug}`);
        });

        function showBreakingPopup(title, url) {
            const popup = document.getElementById('breaking-popup');
            const text = document.getElementById('breaking-popup-text');
            const link = document.getElementById('breaking-popup-link');

            if (!popup || !text || !link) return;

            text.textContent = title;
            link.href = url;
            popup.style.display = 'block';

            setTimeout(closeBreakingPopup, 8000);
        }

        function closeBreakingPopup() {
            const popup = document.getElementById('breaking-popup');
            if (popup) popup.style.display = 'none';
        }

        setTimeout(() => { popupShown = true; }, 3000);
    </script>

    <!-- ========== BACK TO TOP ========== -->
    <button id="back-to-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Back to top">
        <i class="fas fa-arrow-up"></i>
    </button>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Night Mode Toggle
        function toggleNightMode() {
            document.body.classList.toggle('night-mode');
            const isNightMode = document.body.classList.contains('night-mode');
            localStorage.setItem('nightMode', isNightMode ? 'enabled' : 'disabled');

            const toggleBtn = document.getElementById('nightModeToggle');
            if (toggleBtn) {
                const icon = toggleBtn.querySelector('i');
                const span = toggleBtn.querySelector('span');
                if (isNightMode) {
                    icon.className = 'fas fa-sun';
                    span.textContent = 'ডে মোড';
                } else {
                    icon.className = 'fas fa-moon';
                    span.textContent = 'নাইট মোড';
                }
            }
        }

        // Check saved night mode preference
        function initNightMode() {
            const savedMode = localStorage.getItem('nightMode');
            const toggleBtn = document.getElementById('nightModeToggle');

            if (savedMode === 'enabled') {
                document.body.classList.add('night-mode');
                if (toggleBtn) {
                    toggleBtn.querySelector('i').className = 'fas fa-sun';
                    toggleBtn.querySelector('span').textContent = 'ডে মোড';
                }
            }
        }

        // Date display
        const now = new Date();
        const banglaMonths = ['জানুয়ারি','ফেব্রুয়ারি','মার্চ','এপ্রিল','মে','জুন','জুলাই','আগস্ট','সেপ্টেম্বর','অক্টোবর','নভেম্বর','ডিসেম্বর'];
        const banglaWeekdays = ['রবিবার','সোমবার','মঙ্গলবার','বুধবার','বৃহস্পতিবার','শুক্রবার','শনিবার'];

        const weekday = banglaWeekdays[now.getDay()];
        const day = now.getDate();
        const month = banglaMonths[now.getMonth()];
        const year = now.getFullYear();

        const banglaDateElem = document.getElementById('bangla-date');
        if(banglaDateElem) banglaDateElem.innerText = `${weekday}, ${day} ${month} ${year}`;

        const liveDateElem = document.getElementById('live-date');
        if(liveDateElem) liveDateElem.innerText = now.toLocaleDateString('bn-BD', { year: 'numeric', month: 'short', day: 'numeric' });

        // LIVE CLOCK in navigation
        function updateLiveClock() {
            const clockElem = document.getElementById('liveClockNav');
            if(clockElem) {
                const nowTime = new Date();
                let hours = nowTime.getHours();
                const minutes = nowTime.getMinutes().toString().padStart(2,'0');
                const seconds = nowTime.getSeconds().toString().padStart(2,'0');
                const ampm = hours >= 12 ? 'PM' : 'AM';
                hours = hours % 12 || 12;
                clockElem.innerText = `${hours.toString().padStart(2,'0')}:${minutes}:${seconds} ${ampm}`;
            }
        }
        updateLiveClock();
        setInterval(updateLiveClock, 1000);

        // Back to top
        const backBtn = document.getElementById('back-to-top');
        window.addEventListener('scroll', () => {
            if(window.scrollY > 400) backBtn.classList.add('show');
            else backBtn.classList.remove('show');
        });

        // Search
        const searchBtn = document.getElementById('search-btn');
        const searchInput = document.getElementById('live-search-input');

        if(searchBtn && searchInput) {
            searchBtn.addEventListener('click', () => {
                const searchTerm = searchInput.value.trim();
                if(searchTerm) {
                    window.location.href = `/search?q=${encodeURIComponent(searchTerm)}`;
                } else {
                    alert('অনুগ্রহ করে অনুসন্ধান শব্দ লিখুন');
                }
            });

            searchInput.addEventListener('keypress', (e) => {
                if(e.key === 'Enter') {
                    searchBtn.click();
                }
            });
        }

        // Logo check and display
        function checkAndDisplayLogo() {
            const mainLogoImg = document.getElementById('mainLogoImg');
            const mainLogoIcon = document.getElementById('mainLogoIcon');
            const footerLogoImg = document.getElementById('footerLogoImg');
            const footerLogoIcon = document.getElementById('footerLogoIcon');

            if(mainLogoImg && mainLogoImg.complete && mainLogoImg.naturalWidth > 0) {
                mainLogoIcon.classList.add('has-logo');
            }

            if(footerLogoImg && footerLogoImg.complete && footerLogoImg.naturalWidth > 0) {
                footerLogoIcon.classList.add('has-logo');
            }
        }

        setTimeout(checkAndDisplayLogo, 100);

        // Newsletter subscription functions
        function subscribeNewsletter() {
            const emailInput = document.getElementById('newsletter-email');
            const msgDiv = document.getElementById('newsletter-msg');

            if (!emailInput || !emailInput.value.trim()) {
                if (msgDiv) msgDiv.textContent = 'অনুগ্রহ করে আপনার ইমেইল দিন';
                return;
            }

            const email = emailInput.value.trim();
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(email)) {
                if (msgDiv) msgDiv.textContent = 'একটি বৈধ ইমেইল ঠিকানা দিন';
                return;
            }

            // Here you would typically send to server
            if (msgDiv) {
                msgDiv.textContent = 'ধন্যবাদ! আপনি সফলভাবে সাবস্ক্রাইব করেছেন।';
                msgDiv.style.color = '#4ade80';
            }
            emailInput.value = '';
        }

        function subscribeFooterNewsletter() {
            const emailInput = document.getElementById('footer-newsletter-email');

            if (!emailInput || !emailInput.value.trim()) {
                alert('অনুগ্রহ করে আপনার ইমেইল দিন');
                return;
            }

            const email = emailInput.value.trim();
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(email)) {
                alert('একটি বৈধ ইমেইল ঠিকানা দিন');
                return;
            }

            alert('ধন্যবাদ! আপনি সফলভাবে সাবস্ক্রাইব করেছেন।');
            emailInput.value = '';
        }

        // Session storage
        @if (Context.Session.GetString("UserToken") != null)
        {
                <text>
                sessionStorage.setItem('userToken', '@Context.Session.GetString("UserToken")');
                sessionStorage.setItem('userName', '@Context.Session.GetString("UserNameBn")');
                </text>
        }

        // Ensure live ticker duplication for seamless loop
        const ticker = document.getElementById('breaking-ticker');
        if(ticker && ticker.children.length > 2) {
            const cloneItems = Array.from(ticker.children).slice(0, Math.ceil(ticker.children.length/2));
            cloneItems.forEach(el => ticker.appendChild(el.cloneNode(true)));
        }

        // Initialize night mode on page load
        initNightMode();
    </script>

    <script>
        function setGlobalLang(lang) {
            localStorage.setItem('lang', lang);

            const btnBn = document.getElementById('lang-bn');
            const btnEn = document.getElementById('lang-en');

            if (lang === 'bn') {
                if (btnBn) { btnBn.style.background = '#c0392b'; btnBn.style.color = 'white'; }
                if (btnEn) { btnEn.style.background = 'transparent'; btnEn.style.color = '#888'; }
            } else {
                if (btnEn) { btnEn.style.background = '#c0392b'; btnEn.style.color = 'white'; }
                if (btnBn) { btnBn.style.background = 'transparent'; btnBn.style.color = '#888'; }
            }

            document.querySelectorAll('[data-bn]').forEach(el => {
                el.textContent = lang === 'bn'
                    ? el.getAttribute('data-bn')
                    : el.getAttribute('data-en') || el.getAttribute('data-bn');
            });

            document.querySelectorAll('[data-title-bn]').forEach(el => {
                el.textContent = lang === 'bn'
                    ? el.getAttribute('data-title-bn')
                    : el.getAttribute('data-title-en') || el.getAttribute('data-title-bn');
            });
        }

        const savedLang = localStorage.getItem('lang') || 'bn';
        document.addEventListener('DOMContentLoaded', () => {
            setGlobalLang(savedLang);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>