@{
    var position = ViewBag.AdPosition ?? 1;
}
<div class="widget ad-widget" id="ad-zone-@position">
    <div style="font-size:11px;color:#aaa;text-align:center;margin-bottom:4px;">
        বিজ্ঞাপন
    </div>
    <div id="ad-content-@position"
         style="min-height:100px;background:#f9f9f9;border-radius:6px;display:flex;align-items:center;justify-content:center;">
        <span style="font-size:12px;color:#ccc;">লোড হচ্ছে...</span>
    </div>
</div>

<script>
    (async function() {
        try {
            const res = await fetch(
                'https://localhost:7001/api/v1/ad/zone/@position');
            const data = await res.json();
            const container = document.getElementById('ad-content-@position');
            if (!container) return;

            if (data.success && data.data) {
                const ad = data.data;
                container.innerHTML = `
                    <a href="${ad.targetUrl}" target="_blank"
                       style="display:block;">
                        <img src="${ad.imageUrl}"
                             alt="${ad.title}"
                             style="width:100%;border-radius:6px;"/>
                    </a>`;
            } else {
                container.innerHTML = '';
                document.getElementById('ad-zone-@position').style.display = 'none';
            }
        } catch {
            const zone = document.getElementById('ad-zone-@position');
            if (zone) zone.style.display = 'none';
        }
    })();
</script>