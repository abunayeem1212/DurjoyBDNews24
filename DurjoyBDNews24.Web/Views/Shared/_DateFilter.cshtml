<div style="background:white;border-radius:8px;padding:16px;margin-bottom:16px;border:0.5px solid #e0e0e0;">
    <h3 style="font-size:14px;font-weight:500;margin:0 0 12px;color:#555;">
        <i class="fas fa-calendar-alt" style="color:#c0392b;margin-right:6px;"></i>
        তারিখ অনুযায়ী ফিল্টার
    </h3>
    <div style="display:flex;flex-direction:column;gap:8px;">
        <input type="date"
               id="date-filter"
               style="width:100%;padding:8px 10px;border:0.5px solid #ddd;border-radius:6px;font-size:14px;font-family:inherit;outline:none;"
               onchange="filterByDate(this.value)" />
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <button onclick="filterByDate('today')"
                    style="padding:5px 12px;border-radius:20px;border:0.5px solid #ddd;background:#f9f9f9;font-size:12px;cursor:pointer;font-family:inherit;">
                আজ
            </button>
            <button onclick="filterByDate('yesterday')"
                    style="padding:5px 12px;border-radius:20px;border:0.5px solid #ddd;background:#f9f9f9;font-size:12px;cursor:pointer;font-family:inherit;">
                গতকাল
            </button>
            <button onclick="filterByDate('week')"
                    style="padding:5px 12px;border-radius:20px;border:0.5px solid #ddd;background:#f9f9f9;font-size:12px;cursor:pointer;font-family:inherit;">
                এই সপ্তাহ
            </button>
            <button onclick="filterByDate('month')"
                    style="padding:5px 12px;border-radius:20px;border:0.5px solid #ddd;background:#f9f9f9;font-size:12px;cursor:pointer;font-family:inherit;">
                এই মাস
            </button>
            <button onclick="filterByDate('')"
                    style="padding:5px 12px;border-radius:20px;border:0.5px solid #fde8e8;background:#fde8e8;color:#c0392b;font-size:12px;cursor:pointer;font-family:inherit;">
                সব
            </button>
        </div>
    </div>
</div>

<script>
    function filterByDate(value) {
        let date = value;
        const today = new Date();

        if (value === 'today') {
            date = today.toISOString().split('T')[0];
        } else if (value === 'yesterday') {
            const y = new Date(today);
            y.setDate(y.getDate() - 1);
            date = y.toISOString().split('T')[0];
        } else if (value === 'week') {
            const w = new Date(today);
            w.setDate(w.getDate() - 7);
            date = w.toISOString().split('T')[0];
        } else if (value === 'month') {
            const m = new Date(today);
            m.setMonth(m.getMonth() - 1);
            date = m.toISOString().split('T')[0];
        }

        const url = new URL(window.location.href);
        if (date) {
            url.searchParams.set('date', date);
        } else {
            url.searchParams.delete('date');
        }
        url.searchParams.set('page', '1');
        window.location.href = url.toString();
    }
</script>