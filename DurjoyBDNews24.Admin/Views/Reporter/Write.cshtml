@model DurjoyBDNews24.Admin.Models.ArticleFormViewModel
@{
    ViewData["Title"] = "নতুন নিউজ লিখুন";
    var role = Context.Session.GetString("AdminRole");
}

<form asp-action="Write" method="post">
    <div class="form-layout">
        <div class="form-main">
            <div class="form-card">
                <h3>নিউজের বিষয়বস্তু</h3>
                <div class="form-group">
                    <label>বাংলা শিরোনাম *</label>
                    <input asp-for="TitleBn"
                           placeholder="বাংলায় শিরোনাম লিখুন" />
                </div>
                <div class="form-group">
                    <label>English Title</label>
                    <input asp-for="Title"
                           placeholder="English title (optional)" />
                </div>
                <div class="form-group">
                    <label>সারসংক্ষেপ</label>
                    <textarea asp-for="SummaryBn"
                              rows="3"
                              placeholder="সংক্ষিপ্ত বিবরণ (সর্বোচ্চ ২-৩ লাইন)"></textarea>
                </div>
                <div class="form-group">
                    <label>বিস্তারিত বিষয়বস্তু *</label>
                    <textarea asp-for="ContentBn"
                              rows="20"
                              id="content-bn"
                              placeholder="নিউজের বিস্তারিত লিখুন..."></textarea>
                </div>
            </div>

            <div class="form-card">
                <h3>SEO</h3>
                <div class="form-group">
                    <label>Meta Title</label>
                    <input asp-for="MetaTitle"
                           placeholder="Search engine title" />
                </div>
                <div class="form-group">
                    <label>Meta Description</label>
                    <textarea asp-for="MetaDescription"
                              rows="2"
                              placeholder="Search engine description"></textarea>
                </div>
                <div class="form-group">
                    <label>Keywords</label>
                    <input asp-for="MetaKeywords"
                           placeholder="keyword1, keyword2, keyword3" />
                </div>
            </div>
        </div>

        <div class="form-sidebar">
            <div class="form-card">
                <h3>প্রকাশনা তথ্য</h3>

                <div class="form-group">
                    <label>বিভাগ *</label>
                    <select asp-for="CategoryId">
                        <option value="">বিভাগ বেছে নিন</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id">@cat.NameBn</option>
                            @foreach (var child in cat.Children)
                            {
                                <option value="@child.Id">
                                    &nbsp;&nbsp;— @child.NameBn
                                </option>
                            }
                        }
                    </select>
                </div>

                @if (role is "SuperAdmin" or "Editor")
                {
                    <div class="form-check">
                        <input asp-for="IsPublished" type="checkbox" />
                        <label>এখনই প্রকাশ করুন</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="IsBreaking" type="checkbox" />
                        <label>ব্রেকিং নিউজ</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="IsFeatured" type="checkbox" />
                        <label>ফিচার নিউজ</label>
                    </div>
                }
                else
                {
                    <div style="background:#fff3cd;border-radius:6px;padding:12px;font-size:13px;color:#856404;margin-bottom:12px;">
                        <i class="fas fa-info-circle"></i>
                        জমা দেওয়ার পরে Editor অনুমোদন করলে প্রকাশিত হবে।
                    </div>
                }

                <button type="submit" class="btn-primary btn-block">
                    <i class="fas fa-paper-plane"></i>
                    @(role == "Reporter" ? "জমা দিন" : "সংরক্ষণ করুন")
                </button>

                <a asp-action="Index"
                   style="display:block;text-align:center;margin-top:10px;font-size:13px;color:#888;text-decoration:none;">
                    বাতিল করুন
                </a>
            </div>

            <div class="form-card">
                <h3>থাম্বনেইল ছবি</h3>
                <div class="form-group">
                    <label>ছবি upload করুন</label>
                    <input type="file"
                           id="image-file"
                           accept="image/*"
                           style="padding:6px;width:100%;" />
                    <button type="button"
                            id="upload-btn"
                            class="btn-primary"
                            style="margin-top:8px;width:100%;">
                        <i class="fas fa-upload"></i> Upload করুন
                    </button>
                    <div id="upload-status"
                         style="font-size:13px;margin-top:6px;"></div>
                </div>
                <div class="form-group">
                    <label>অথবা URL দিন</label>
                    <input asp-for="ThumbnailUrl"
                           id="thumbnail-url"
                           placeholder="https://..." />
                </div>
                <div id="thumbnail-preview">
                    @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                    {
                        <img src="@Model.ThumbnailUrl"
                             style="width:100%;border-radius:6px;margin-top:8px" />
                    }
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const apiBase = 'https://localhost:7001/api/v1/';
        const adminToken = '@Context.Session.GetString("AdminToken")';

        document.getElementById('upload-btn')
            ?.addEventListener('click', async function () {
            const fileInput = document.getElementById('image-file');
            const status = document.getElementById('upload-status');
            const urlInput = document.getElementById('thumbnail-url');
            const preview = document.getElementById('thumbnail-preview');

            if (!fileInput.files.length) {
                status.textContent = 'ফাইল নির্বাচন করুন';
                status.style.color = 'red';
                return;
            }

            const formData = new FormData();
            formData.append('file', fileInput.files[0]);

            status.textContent = 'upload হচ্ছে...';
            status.style.color = '#888';
            this.disabled = true;

            try {
                const res = await fetch(
                    `${apiBase}media/upload?folder=articles`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${adminToken}`
                    },
                    body: formData
                });

                const data = await res.json();
                if (data.success) {
                    urlInput.value = data.data;
                    preview.innerHTML =
                        `<img src="${data.data}"
                              style="width:100%;border-radius:6px;margin-top:8px"/>`;
                    status.textContent = 'upload সফল হয়েছে';
                    status.style.color = 'green';
                } else {
                    status.textContent = data.message || 'upload ব্যর্থ';
                    status.style.color = 'red';
                }
            } catch {
                status.textContent = 'সংযোগ সমস্যা';
                status.style.color = 'red';
            } finally {
                this.disabled = false;
            }
        });

        document.getElementById('thumbnail-url')
            ?.addEventListener('input', function () {
            const preview = document.getElementById('thumbnail-preview');
            preview.innerHTML = this.value
                ? `<img src="${this.value}"
                        style="width:100%;border-radius:6px;margin-top:8px"/>`
                : '';
        });
    </script>
}