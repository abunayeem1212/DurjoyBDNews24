@model IEnumerable<DurjoyBDNews24.Application.DTOs.EPaper.EPaperDto>
@{
    ViewData["Title"] = "ই-পেপার ম্যানেজমেন্ট";
}

<div class="page-header">
    <h2>ই-পেপার</h2>
    <a asp-action="Create" class="btn-primary">
        + নতুন সংখ্যা যোগ করুন
    </a>
</div>

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;">
    @foreach (var ep in Model)
    {
        <div style="background:white;border-radius:8px;overflow:hidden;border:0.5px solid #e0e0e0;">
            @if (!string.IsNullOrEmpty(ep.ThumbnailUrl))
            {
                <img src="@ep.ThumbnailUrl"
                     style="width:100%;height:160px;object-fit:cover;display:block;" />
            }
            else
            {
                <div style="height:160px;background:linear-gradient(135deg,#1a1a2e,#c0392b);display:flex;align-items:center;justify-content:center;">
                    <i class="fas fa-newspaper" style="font-size:36px;color:white;opacity:0.5;"></i>
                </div>
            }
            <div style="padding:12px;">
                <p style="font-size:13px;font-weight:500;margin:0 0 4px;color:#1a1a1a;">
                    @ep.PublishDateBn
                </p>
                <div style="display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap;">
                    @if (ep.IsPremiumOnly)
                    {
                        <span class="badge" style="background:#fff3cd;color:#856404;">
                            <i class="fas fa-crown"></i> Premium
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(ep.Edition))
                    {
                        <span class="badge gray">@ep.Edition</span>
                    }
                </div>
                <div style="display:flex;gap:6px;font-size:12px;color:#888;margin-bottom:10px;">
                    <span><i class="fas fa-eye"></i> @ep.ViewCount</span>
                    <span><i class="fas fa-download"></i> @ep.DownloadCount</span>
                </div>
                <form asp-action="Delete"
                      asp-route-id="@ep.Id"
                      method="post"
                      onsubmit="return confirm('মুছে ফেলবেন?')">
                    <button type="submit" class="btn-sm red"
                            style="width:100%;">
                        <i class="fas fa-trash"></i> মুছুন
                    </button>
                </form>
            </div>
        </div>
    }
</div>